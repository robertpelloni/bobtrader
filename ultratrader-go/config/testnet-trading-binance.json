{
  "environment": "testnet-verification",
  "server": {
    "enabled": true,
    "address": "0.0.0.0:8500"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 1000
  },
  "risk": {
    "max_notional": 100,
    "max_notional_per_symbol": 50,
    "allowed_symbols": ["BTCUSDT", "ETHUSDT"],
    "cooldown_ms": 30000,
    "duplicate_window_ms": 60000,
    "duplicate_side_window_ms": 30000,
    "max_open_positions": 2,
    "max_concentration_pct": 100
  },
  "strategy": {
    "risk_pct": 2.0,
    "max_notional": 100,
    "trailing_activate_pct": 1.0,
    "trailing_gap_pct": 0.3,
    "trailing_stop_loss_pct": 3.0,
    "trailing_max_hold_minutes": 10,
    "bollinger_period": 20,
    "bollinger_std_dev": 2.0,
    "rsi_period": 14,
    "rsi_oversold": 30,
    "rsi_overbought": 70,
    "ema_fast": 9,
    "ema_slow": 21
  },
  "market_data": {
    "source": "websocket",
    "initial_balance": 10000
  },
  "accounts": [
    {
      "id": "binance-testnet",
      "name": "Binance Testnet Account",
      "enabled": false,
      "exchange": "binance",
      "api_key": "YOUR_TESTNET_API_KEY",
      "secret_key": "YOUR_TESTNET_SECRET_KEY",
      "testnet": true,
      "capabilities": ["spot", "balances", "orders", "candles", "tickers"]
    }
  ]
}
