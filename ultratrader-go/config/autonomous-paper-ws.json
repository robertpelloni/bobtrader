{
  "environment": "autonomous-paper-websocket",
  "server": {
    "enabled": true,
    "address": "0.0.0.0:8301"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 1000
  },
  "risk": {
    "max_notional": 500,
    "max_notional_per_symbol": 250,
    "allowed_symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
    "cooldown_ms": 10000,
    "duplicate_window_ms": 15000,
    "duplicate_side_window_ms": 10000,
    "max_open_positions": 5,
    "max_concentration_pct": 90
  },
  "strategy": {
    "risk_pct": 2.0,
    "max_notional": 500,
    "trailing_activate_pct": 1.0,
    "trailing_gap_pct": 0.3,
    "trailing_stop_loss_pct": 3.0,
    "trailing_max_hold_minutes": 5,
    "bollinger_period": 20,
    "bollinger_std_dev": 2.0,
    "rsi_period": 14,
    "rsi_oversold": 35,
    "rsi_overbought": 65,
    "ema_fast": 9,
    "ema_slow": 21
  },
  "market_data": {
    "source": "websocket",
    "initial_balance": 10000
  },
  "accounts": [
    {
      "id": "paper-main",
      "name": "Paper Trading (Live Binance WS Data)",
      "enabled": true,
      "exchange": "paper-market-aware",
      "capabilities": ["spot", "paper", "candles", "balances", "orders"]
    }
  ]
}
