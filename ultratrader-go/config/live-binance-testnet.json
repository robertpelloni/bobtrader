{
  "environment": "live-binance-testnet",
  "server": {
    "enabled": true,
    "address": "0.0.0.0:8300"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 5000
  },
  "risk": {
    "max_notional": 50,
    "max_notional_per_symbol": 25,
    "allowed_symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
    "cooldown_ms": 30000,
    "duplicate_window_ms": 60000,
    "duplicate_side_window_ms": 30000,
    "max_open_positions": 3,
    "max_concentration_pct": 50
  },
  "strategy": {
    "risk_pct": 1.0,
    "max_notional": 50,
    "trailing_activate_pct": 1.0,
    "trailing_gap_pct": 0.3,
    "trailing_stop_loss_pct": 3.0,
    "trailing_max_hold_minutes": 10,
    "bollinger_period": 20,
    "bollinger_std_dev": 2.0,
    "rsi_period": 14,
    "rsi_oversold": 35,
    "rsi_overbought": 65,
    "ema_fast": 9,
    "ema_slow": 21
  },
  "market_data": {
    "source": "websocket",
    "initial_balance": 10000
  },
  "accounts": [
    {
      "id": "binance-testnet",
      "name": "Binance Spot Testnet",
      "enabled": true,
      "exchange": "binance",
      "secrets_file": "config/secrets/binance-testnet.json",
      "testnet": true,
      "capabilities": ["spot", "candles", "balances", "orders"]
    }
  ]
}
