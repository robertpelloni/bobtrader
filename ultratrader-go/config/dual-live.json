    "duplicate_window_ms": 60000,
    "duplicate_side_window_ms": 30000,
    "max_open_positions": 2,
    "max_concentration_pct": 100
  },
  "strategy": {
    "risk_pct": 95.0,
    "max_notional": 25,
    "trailing_activate_pct": 1.0,
    "trailing_gap_pct": 0.5,
    "trailing_stop_loss_pct": 3.0,
    "trailing_max_hold_minutes": 120,
    "bollinger_period": 15,
    "bollinger_std_dev": 1.5,
    "rsi_period": 10,
    "rsi_oversold": 35,
    "rsi_overbought": 65,
    "ema_fast": 5,
    "ema_slow": 13
  },
  "market_data": {
    "source": "rest",
    "initial_balance": 50
  },
  "accounts": [
    {
      "id": "binance-dual-live",
      "name": "Binance Dual ETH+ADA Live",
      "enabled": true,
      "exchange": "binance",
      "secrets_file": "config/secrets/binance-production.json",
      "testnet": false,
      "capabilities": ["spot", "balances", "orders", "candles", "tickers"]
    }
  ]
