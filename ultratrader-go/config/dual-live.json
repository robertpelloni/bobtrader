{
  "environment": "dual-eth-ada-live",
  "server": {
    "enabled": true,
    "address": "0.0.0.0:8300"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 5000
  },
  "risk": {
    "max_notional": 25,
    "max_notional_per_symbol": 25,
    "allowed_symbols": ["ETHUSDT", "ADAUSDT"],
