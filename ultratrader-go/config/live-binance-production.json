{
  "environment": "live-binance-production",
  "server": {
    "enabled": true,
    "address": "127.0.0.1:8300"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 5000
  },
  "risk": {
    "max_notional": 100,
    "max_notional_per_symbol": 50,
    "allowed_symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
    "cooldown_ms": 60000,
    "duplicate_window_ms": 120000,
    "duplicate_side_window_ms": 60000,
    "max_open_positions": 3,
    "max_concentration_pct": 40
  },
  "strategy": {
    "risk_pct": 1.0,
    "max_notional": 100,
    "trailing_activate_pct": 1.5,
    "trailing_gap_pct": 0.5,
    "trailing_stop_loss_pct": 2.0,
    "trailing_max_hold_minutes": 30,
    "bollinger_period": 20,
    "bollinger_std_dev": 2.0,
    "rsi_period": 14,
    "rsi_oversold": 30,
    "rsi_overbought": 70,
    "ema_fast": 9,
    "ema_slow": 21
  },
  "market_data": {
    "source": "rest",
    "initial_balance": 0
  },
  "accounts": [
    {
      "id": "binance-live",
      "name": "Binance Spot Live",
      "enabled": true,
      "exchange": "binance",
      "api_key": "YOUR_REAL_API_KEY",
      "secret_key": "YOUR_REAL_SECRET_KEY",
      "testnet": false,
      "capabilities": ["spot", "candles", "balances", "orders"]
    }
  ]
}
