{
  "environment": "eth-live",
  "server": {
    "enabled": true,
    "address": "0.0.0.0:8300"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 15000
  },
  "risk": {
    "max_notional": 55,
    "max_notional_per_symbol": 55,
    "allowed_symbols": ["ETHUSDT"],
    "cooldown_ms": 30000,
    "duplicate_window_ms": 1000,
    "duplicate_side_window_ms": 60000,
    "max_open_positions": 1,
    "max_concentration_pct": 100
  },
  "strategy": {
    "risk_pct": 90.0,
    "max_notional": 55,
    "trailing_activate_pct": 1.0,
    "trailing_gap_pct": 0.3,
    "trailing_stop_loss_pct": 2.0,
    "trailing_max_hold_minutes": 60,
    "bollinger_period": 20,
    "bollinger_std_dev": 2.0,
    "rsi_period": 14,
    "rsi_oversold": 30,
    "rsi_overbought": 70,
    "ema_fast": 9,
    "ema_slow": 21
  },
  "market_data": {
    "source": "rest",
    "initial_balance": 55
  },
  "accounts": [
    {
      "id": "binance-eth-live",
      "name": "Binance ETH Live Trading",
      "enabled": true,
      "exchange": "binance",
      "secrets_file": "config/secrets/binance-production.json",
      "testnet": false,
      "capabilities": ["spot", "balances", "orders", "candles", "tickers"]
    }
  ]
}
