{
  "environment": "production-live-trading",
  "server": {
    "enabled": true,
    "address": "0.0.0.0:8400"
  },
  "scheduler": {
    "enabled": true,
    "mode": "stream",
    "interval_ms": 1000
  },
  "risk": {
    "max_notional": 200,
    "max_notional_per_symbol": 100,
    "allowed_symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
    "cooldown_ms": 60000,
    "duplicate_window_ms": 300000,
    "duplicate_side_window_ms": 150000,
    "max_open_positions": 3,
    "max_concentration_pct": 40
  },
  "strategy": {
    "risk_pct": 1.0,
    "max_notional": 100,
    "trailing_activate_pct": 1.5,
    "trailing_gap_pct": 0.5,
    "trailing_stop_loss_pct": 2.0,
    "trailing_max_hold_minutes": 15,
    "bollinger_period": 20,
    "bollinger_std_dev": 2.0,
    "rsi_period": 14,
    "rsi_oversold": 30,
    "rsi_overbought": 70,
    "ema_fast": 9,
    "ema_slow": 21
  },
  "market_data": {
    "source": "websocket",
    "initial_balance": 10000
  },
  "accounts": [
    {
      "id": "binance-live",
      "name": "Binance Live Account",
      "enabled": false,
      "exchange": "binance",
      "api_key": "YOUR_BINANCE_API_KEY",
      "secret_key": "YOUR_BINANCE_SECRET_KEY",
      "testnet": false,
      "capabilities": ["spot", "balances", "orders", "candles", "tickers"]
    }
  ]
}
